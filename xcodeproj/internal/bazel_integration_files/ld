#!/bin/bash

set -euo pipefail

# Debug logging for preview builds - using stderr for sandbox compatibility
echo "=== LD SCRIPT CALLED: $(date) ===" >&1
echo "Arguments: $*" >&1
echo "PWD: $PWD" >&1
echo "ENABLE_PREVIEWS: ${ENABLE_PREVIEWS:-not_set}" >&1

# Enhanced preview helper functions (integrated directly for reliability)

# Enhanced multi-signal preview detection with early-exit optimization
detect_preview_build() {
    local is_preview=false
    
    # Signal 1: Environment variable
    if [[ "${ENABLE_PREVIEWS:-}" == "YES" ]]; then
        is_preview=true
        echo "$is_preview"
        return
    fi
    
    # Signal 2: Swift preview-specific linker flags (Xcode 15+)
    for arg in "$@"; do
        if [[ "$arg" == "-swift-allow-older-dylib" ]]; then
            is_preview=true
            echo "$is_preview"
            return
        fi
    done
    
    # Signal 3: Output path patterns
    for arg in "$@"; do
        if [[ "$arg" == *"preview"* ]] || [[ "$arg" == *"Preview"* ]] || [[ "$arg" == *".preview-thunk.dylib" ]]; then
            is_preview=true
            echo "$is_preview"
            return
        fi
    done
    
    # Signal 4: SwiftPM preview thunk environment
    if [[ "${LLVM_TARGET_TRIPLE_SUFFIX:-}" == "preview_thunk" ]]; then
        is_preview=true
        echo "$is_preview"
        return
    fi
    
    # Signal 5: Xcode build settings
    if [[ "${SWIFT_ENABLE_PREVIEWS:-}" == "YES" ]] || [[ "${XCODE_PREVIEWS_ENABLED:-}" == "YES" ]]; then
        is_preview=true
        echo "$is_preview"
        return
    fi
    
    # Signal 6: Build configuration (with false positive guard for CI)
    if [[ "${CONFIGURATION:-}" == *"Preview"* ]] || [[ "${BUILD_VARIANTS:-}" == *"preview"* ]]; then
        # Guard against false positives for CI environments
        if [[ "${ACTION:-}" == "build" ]] && [[ "${RUN_DESTINATION:-}" == *"Simulator"* ]] && [[ "${RUN_DESTINATION:-}" == *"Preview"* ]]; then
            is_preview=true
        fi
    fi
    
    echo "$is_preview"
}

# Detect static libraries containing Swift metadata using archive inspection
detect_swift_static_libraries() {
    local swift_libs=()
    
    for arg in "$@"; do
        # Only check files that could be static libraries
        if [[ -f "$arg" ]] && [[ "$arg" == *.a ]]; then
            # Use archive inspection to detect Swift metadata (more reliable than filename patterns)
            if command -v ar >/dev/null 2>&1; then
                # Check for Swift metadata OR ObjC classes (Swift-wrapped ObjC)
                if ar -t "$arg" 2>/dev/null | grep -q "__swift5" || \
                   /usr/bin/grep -q "__swift5" <(ar -t "$arg" 2>/dev/null) || \
                   ar -t "$arg" 2>/dev/null | grep -q "_OBJC_CLASS_" || \
                   ar -t "$arg" 2>/dev/null | grep -q "_OBJC_METACLASS_"; then
                    swift_libs+=("$arg")
                    echo "Detected Swift/ObjC hybrid library via archive inspection: $arg" >&1
                fi
            fi
        fi
    done
    
    echo "${swift_libs[@]}"
}

# Apply Swift runtime configuration to all preview builds
setup_swift_runtime_for_previews() {
    local is_preview="$1"
    
    if [[ "$is_preview" == "true" ]]; then
        echo "Setting up Swift runtime for preview build..." >&1
        
        # CRITICAL: Add -all_load at the VERY BEGINNING to ensure it applies to all archives
        # This must be the first thing we add to ensure proper argument ordering
        if [[ " ${passthrough_args[*]} " != *" -Wl,-all_load "* ]]; then
            passthrough_args=("-Wl,-all_load" "${passthrough_args[@]}")
            echo "Added -all_load at beginning of command line" >&1
        fi
        
        # Export all symbols for JIT (with dead strip protection)
        passthrough_args+=("-Wl,-export_dynamic")
        # Prevent hitting 50k dylib symbol limit by keeping unused dependencies stripped
        passthrough_args+=("-Wl,-dead_strip_dylibs")
        echo "Added symbol export with dead strip protection" >&1
        
        # Add Swift runtime libraries
        passthrough_args+=(
            "-lswiftCore"
            "-lswiftFoundation"
            "-lswiftUIKit"
            "-lswiftObjectiveC"
            "-lswiftSwiftOnoneSupport"  # For preview builds
        )
        echo "Added Swift runtime libraries" >&1
        
        # Add Swift runtime paths (with Intel/Rosetta support)
        if [[ -n "${developer_dir:-}" ]]; then
            # Use xcrun to find paths robustly across Xcode versions
            local swift_toolchain_dir
            if swift_toolchain_dir=$(xcrun --sdk "${SDKROOT:-iphoneos}" --show-sdk-path 2>/dev/null | sed 's|/SDKs/.*|/Toolchains/XcodeDefault.xctoolchain|'); then
                
                if [[ -d "$swift_toolchain_dir" ]]; then
                    # Primary platform-specific path
                    local swift_lib_dir="$swift_toolchain_dir/usr/lib/swift/${platform_name:-iphoneos}"
                    if [[ -d "$swift_lib_dir" ]]; then
                        passthrough_args+=("-L$swift_lib_dir" "-Wl,-rpath,$swift_lib_dir")
                        echo "Added Swift runtime path: $swift_lib_dir" >&1
                    fi
                    
                    # Additional path for Intel/Rosetta builds (Cursor's feedback)
                    if [[ "${platform_name:-iphoneos}" == "iphonesimulator" ]]; then
                        local macos_swift_lib_dir="$swift_toolchain_dir/usr/lib/swift/macosx"
                        if [[ -d "$macos_swift_lib_dir" ]]; then
                            passthrough_args+=("-L$macos_swift_lib_dir" "-Wl,-rpath,$macos_swift_lib_dir")
                            echo "Added Intel/Rosetta Swift runtime path: $macos_swift_lib_dir" >&1
                        fi
                    fi
                fi
            else
                echo "Warning: Could not determine Swift toolchain directory" >&1
            fi
        fi
        
        # Add framework search paths
        passthrough_args+=(
            "-Wl,-rpath,@loader_path/Frameworks"
            "-Wl,-rpath,@executable_path/Frameworks"
        )
        echo "Added framework search paths" >&1
    fi
}

# Apply selective force-loading to avoid duplicate symbol issues
force_load_swift_libraries() {
    local is_preview="$1"
    shift
    local swift_libraries=("$@")
    
    if [[ "$is_preview" == "true" ]]; then
        echo "Applying selective force-loading for ${#swift_libraries[@]} Swift libraries..." >&1
        
        # Use selective force-loading instead of global -all_load to avoid duplicate symbols
        for lib in "${swift_libraries[@]}"; do
            if [[ -f "$lib" ]]; then
                passthrough_args+=("-Wl,-force_load,$lib")
                echo "Force-loading Swift library: $lib" >&1
            else
                echo "Warning: Swift library not found: $lib" >&1
            fi
        done
    fi
}

# Command line debugging function
debug_command_line() {
    if [[ "${LD_WRAPPER_DEBUG:-}" == "YES" ]]; then
        echo "=== COMMAND LINE DEBUG ===" >&1
        echo "Full command: ${passthrough_args[*]}" >&1
        echo "Args count: ${#passthrough_args[@]}" >&1
        
        # Check for key flags and their positions
        local i=0
        for arg in "${passthrough_args[@]}"; do
            if [[ "$arg" == "-Wl,-all_load" ]]; then
                echo "Found -all_load at position: $((i+1))" >&1
            elif [[ "$arg" == "-Wl,-force_load,"* ]]; then
                echo "Found force_load at position $((i+1)): $arg" >&1
            elif [[ "$arg" == "-Wl,-export_dynamic" ]]; then
                echo "Found -export_dynamic at position: $((i+1))" >&1
            fi
            ((i++))
        done
        echo "=========================" >&1
    fi
}

# Logging function for debugging
log_preview_setup() {
    local is_preview="$1"
    local swift_lib_count="$2"
    
    echo "=== PREVIEW SETUP SUMMARY ===" >&1
    echo "Preview build detected: $is_preview" >&1
    echo "Swift libraries found: $swift_lib_count" >&1
    echo "Final passthrough args count: ${#passthrough_args[@]}" >&1
    echo "============================" >&1
    
    # Always call debug_command_line to check for LD_WRAPPER_DEBUG
    debug_command_line
}

# === Persistent trace so we can verify wrapper execution even if stderr is swallowed ===
# Choose a path inside Bazel’s output tree if available, otherwise fallback to $TMPDIR.
log_root="${BAZEL_OUT:-$TMPDIR}"
# Ensure directory exists (ignore errors if TMPDIR already exists).
mkdir -p "$log_root" 2>/dev/null || true
echo "[ld wrapper] $(date '+%Y-%m-%d %H:%M:%S')  $0  $*" >> "$log_root/ld_wrapper.log"
# === End trace ===

passthrough_args=("${@:1}")
has_objc_flag=false
has_clang_rt_flag=false
has_force_load_flag=false
has_blocks_rt_flag=false
developer_dir=""
platform_name=""

# Check if we already have required flags and identify merged static libraries
merged_static_libs=()
for arg in "${@:1}"; do
  if [[ "$arg" == "-ObjC" ]]; then
    has_objc_flag=true
  fi
  if [[ "$arg" == *"clang_rt.ios"* ]]; then
    has_clang_rt_flag=true
  fi
  if [[ "$arg" == "-force_load" ]]; then
    has_force_load_flag=true
  fi
  if [[ "$arg" == *"BlocksRuntime"* ]] || [[ "$arg" == "-lBlocksRuntime" ]]; then
    has_blocks_rt_flag=true
  fi
done

# Add -ObjC flag if not already present (for ObjC category support)
if [[ $has_objc_flag == false ]]; then
  passthrough_args=("-ObjC" "${passthrough_args[@]}")
  echo "Added -ObjC flag" >&1
fi

# Function to add runtime libraries for preview builds
add_runtime_libraries() {
  local preview_mode="$1"
  echo "add_runtime_libraries called with preview_mode: $preview_mode" >&1
  
  # Add clang runtime library for @available checks
  if [[ $has_clang_rt_flag == false && -n "$developer_dir" ]]; then
    echo "Searching for clang runtime library..." >&1
    
    # Try multiple strategies to find clang runtime library
    clang_version=$("$developer_dir/Toolchains/XcodeDefault.xctoolchain/usr/bin/clang" --version 2>/dev/null | head -n1 | sed 's/.*clang-\([0-9][0-9]*\).*/\1/' || echo "")
    if [[ -z "$clang_version" ]]; then
      clang_version=$("$developer_dir/Toolchains/XcodeDefault.xctoolchain/usr/bin/clang" --version 2>/dev/null | head -n1 | sed 's/.* \([0-9][0-9]*\)\.[0-9].*/\1/' || echo "")
    fi
    echo "Detected clang version: $clang_version" >&1
    
    # Strategy 1: Use versioned path
    if [[ -n "$clang_version" ]]; then
      # Use simulator-specific runtime library for simulator builds
      if [[ "${platform_name:-iphoneos}" == "iphonesimulator" ]]; then
        runtime_lib_name="libclang_rt.iossim.a"
      else
        runtime_lib_name="libclang_rt.ios.a"
      fi
      runtime_lib_path="$developer_dir/Toolchains/XcodeDefault.xctoolchain/usr/lib/clang/$clang_version/lib/darwin/$runtime_lib_name"
      echo "Trying runtime library path: $runtime_lib_path (platform: ${platform_name:-iphoneos})" >&1
      if [[ -f "$runtime_lib_path" ]]; then
        passthrough_args=("${passthrough_args[@]}" "-Wl,-force_load,$runtime_lib_path")
        has_clang_rt_flag=true
        echo "SUCCESS: Force-loaded clang runtime library: $runtime_lib_path" >&1
      else
        echo "FAILED: Runtime library not found at: $runtime_lib_path" >&1
      fi
    fi
    
    # Strategy 2: Search for the library
    if [[ $has_clang_rt_flag == false ]]; then
      echo "Searching for clang runtime library in toolchain..." >&1
      # Use the same platform-specific library name from Strategy 1
      runtime_lib_name="${runtime_lib_name:-libclang_rt.ios.a}"
      runtime_lib_path=$(find "$developer_dir/Toolchains/XcodeDefault.xctoolchain/usr/lib/clang" -name "$runtime_lib_name" 2>/dev/null | head -n1)
      echo "Search result: $runtime_lib_path" >&1
      if [[ -n "$runtime_lib_path" && -f "$runtime_lib_path" ]]; then
        passthrough_args=("${passthrough_args[@]}" "-Wl,-force_load,$runtime_lib_path")
        has_clang_rt_flag=true
        echo "SUCCESS: Found and force-loaded clang runtime library: $runtime_lib_path" >&1
      else
        echo "FAILED: Runtime library not found via search" >&1
      fi
    fi
    
    # Strategy 3: Try linker flag as fallback
    if [[ $has_clang_rt_flag == false ]]; then
      # Use platform-specific linker flag
      if [[ "${platform_name:-iphoneos}" == "iphonesimulator" ]]; then
        runtime_flag="-lclang_rt.iossim"
      else
        runtime_flag="-lclang_rt.ios"
      fi
      passthrough_args=("${passthrough_args[@]}" "$runtime_flag")
      echo "FALLBACK: Added $runtime_flag linker flag" >&1
    fi
  fi
  
  # Add blocks runtime library for block helper functions
  if [[ $has_blocks_rt_flag == false && "$preview_mode" == "true" && -n "$developer_dir" ]]; then
    echo "Searching for BlocksRuntime library..." >&1
    
    # Try to find BlocksRuntime library
    blocks_lib_path="$developer_dir/Toolchains/XcodeDefault.xctoolchain/usr/lib/libBlocksRuntime.a"
    echo "Trying blocks library path: $blocks_lib_path" >&1
    if [[ -f "$blocks_lib_path" ]]; then
      passthrough_args=("${passthrough_args[@]}" "$blocks_lib_path")
      echo "SUCCESS: Added BlocksRuntime library: $blocks_lib_path" >&1
    else
      # Search for it
      blocks_lib_path=$(find "$developer_dir/Toolchains/XcodeDefault.xctoolchain/usr/lib" -name "libBlocksRuntime*" 2>/dev/null | head -n1)
      echo "Search result: $blocks_lib_path" >&1
      if [[ -n "$blocks_lib_path" && -f "$blocks_lib_path" ]]; then
        passthrough_args=("${passthrough_args[@]}" "$blocks_lib_path")
        echo "SUCCESS: Found and added BlocksRuntime library: $blocks_lib_path" >&1
      else
        # Try as linker flag
        passthrough_args=("${passthrough_args[@]}" "-lBlocksRuntime")
        echo "FALLBACK: Added -lBlocksRuntime linker flag" >&1
      fi
    fi
  fi
}

# Function to add Swift linking support for cross-module dependencies
add_swift_linking_support() {
  local preview_mode="$1"
  echo "add_swift_linking_support called with preview_mode: $preview_mode" >&1
  
  # For SwiftUI Previews, we need to ensure all Swift modules are force-loaded
  # to make protocol witness tables and type metadata available at runtime
  if [[ "$preview_mode" == "true" ]]; then
    echo "Adding Swift preview linking support..." >&1
    
    # Add flags to support Swift cross-module dependencies in JIT environment
    # 1. Ensure -all_load is the *first* linker flag so it applies to every
    #    static archive that follows.  We only prepend it if it isn’t already
    #    present so repeated calls don’t duplicate the flag.
    if [[ " ${passthrough_args[*]} " != *" -Wl,-all_load "* ]]; then
      passthrough_args=("-Wl,-all_load" "${passthrough_args[@]}")
    fi

    # 2. Append the rest of the Swift-specific runtime flags/libraries.
    passthrough_args+=(
      "-Wl,-export_dynamic"  # Export all symbols for JIT runtime discovery
      "-lswiftCore"          # Ensure Swift runtime is linked
      "-lswiftFoundation"    # Foundation Swift overlay
      "-lswiftUIKit"         # UIKit Swift overlay (if available)
      "-lswiftObjectiveC"    # ObjC ↔︎ Swift bridging support
    )
    echo "Added Swift runtime libraries" >&1
    echo "Added -export_dynamic for preview symbol export" >&1
    
    # Try to find and force-load Swift runtime libraries
    if [[ -n "$developer_dir" ]]; then
      # Use detected platform name instead of hardcoded iphoneos
      swift_platform_name="${platform_name:-iphoneos}"
      swift_lib_dir="$developer_dir/Toolchains/XcodeDefault.xctoolchain/usr/lib/swift/$swift_platform_name"
      echo "Checking Swift lib directory: $swift_lib_dir (platform: $swift_platform_name)" >&1
      if [[ -d "$swift_lib_dir" ]]; then
        # Add Swift stdlib path for runtime linking
        passthrough_args=("${passthrough_args[@]}" "-L$swift_lib_dir")
        echo "Added Swift stdlib path: $swift_lib_dir" >&1
        
        # Add explicit rpath for Swift runtime libraries
        passthrough_args=("${passthrough_args[@]}" "-Wl,-rpath,$swift_lib_dir")
        echo "Added Swift runtime rpath: $swift_lib_dir" >&1
        
        # For preview builds, try to find and link RxSwift specifically if available
        if [[ -d "$swift_lib_dir/../../../lib" ]]; then
          passthrough_args=("${passthrough_args[@]}" "-L$swift_lib_dir/../../../lib")
          echo "Added additional Swift lib path: $swift_lib_dir/../../../lib" >&1
        fi
      else
        echo "Swift lib directory not found: $swift_lib_dir" >&1
      fi
    fi
    
    # Add additional flags for complex Swift generics and cross-module references
    passthrough_args=("${passthrough_args[@]}"
      "-Wl,-rpath,@loader_path/Frameworks"  # Ensure framework resolution
      "-Wl,-rpath,@executable_path/Frameworks"  # Alternative framework path
    )
    echo "Added additional Swift linking flags" >&1
  fi
}

# Function to force-load merged static libraries for preview builds
force_load_merged_static_libs() {
  local preview_mode="$1"
  echo "force_load_merged_static_libs called with preview_mode: $preview_mode" >&1
  
  if [[ "$preview_mode" == "true" && ${#merged_static_libs[@]} -gt 0 ]]; then
    echo "Force-loading ${#merged_static_libs[@]} merged static libraries for preview build..." >&1
    
    for lib in "${merged_static_libs[@]}"; do
      if [[ -f "$lib" ]]; then
        passthrough_args=("${passthrough_args[@]}" "-Wl,-force_load,$lib")
        echo "Force-loaded merged static library: $lib" >&1
      else
        echo "WARNING: Merged static library not found: $lib" >&1
      fi
    done
  fi
}

while test $# -gt 0
do
  case $1 in
  -version_details)
    echo "Handling -version_details" >&1
    # Pass through for version details
    exec "$(xcrun --find ld)" -version_details
    ;;

  *_dependency_info.dat)
    echo "Handling dependency info: $1" >&1
    ld_version=$(ld -v 2>&1 | grep ^@)
    printf "\0%s\0" "$ld_version" > "$1"
    break
    ;;

  -isysroot)
    shift
    # PATH/DEVELOPER_DIR isn't set when this is called, so we need to calculate
    # the developer dir from the sysroot to invoke clang (used below)
    developer_dir="${1/\/Platforms\/*/}"
    
    # Detect platform dynamically from sysroot path
    if [[ "$1" == *"/Platforms/"* ]]; then
      platform_name=$(basename "$(dirname "$(dirname "$1")")")
      echo "Detected platform: $platform_name from sysroot: $1" >&1
    else
      platform_name="iphoneos"  # fallback
      echo "Using fallback platform: $platform_name" >&1
    fi
    
    echo "Set developer_dir: $developer_dir" >&1
    ;;

  *.preview-thunk.dylib)
    echo "PREVIEW THUNK DETECTED: $1" >&1
    # Pass through for SwiftUI Preview thunk compilation
    
    # Use enhanced preview detection and setup
    is_preview_build=$(detect_preview_build "${@:1}")
    swift_libs=($(detect_swift_static_libraries "${@:1}"))
    
    setup_swift_runtime_for_previews "$is_preview_build"
    force_load_swift_libraries "$is_preview_build" "${swift_libs[@]}"
    log_preview_setup "$is_preview_build" "${#swift_libs[@]}"
    
    echo "Final passthrough_args for preview thunk: ${passthrough_args[*]}" >&1
    
    # TODO: Make this work with custom toolchains
    exec "$developer_dir/Toolchains/XcodeDefault.xctoolchain/usr/bin/clang" "${passthrough_args[@]}"
    ;;

  -o)
    echo "Output linking detected: $2" >&1
    # This is a real linking operation - use clang like preview-thunk does
    
    # Use enhanced preview detection and setup
    is_preview_build=$(detect_preview_build "${@:1}")
    swift_libs=($(detect_swift_static_libraries "${@:1}"))
    
    echo "Enhanced preview detection result: $is_preview_build" >&1
    
    # Apply preview-specific setup
    setup_swift_runtime_for_previews "$is_preview_build"
    force_load_swift_libraries "$is_preview_build" "${swift_libs[@]}"
    log_preview_setup "$is_preview_build" "${#swift_libs[@]}"
    
    echo "Final passthrough_args for output linking: ${passthrough_args[*]}" >&1
    
    # TODO: Make this work with custom toolchains
    exec "$developer_dir/Toolchains/XcodeDefault.xctoolchain/usr/bin/clang" "${passthrough_args[@]}"
    ;;
  esac
  shift
done

echo "=== LD SCRIPT COMPLETED: $(date) ===" >&1
